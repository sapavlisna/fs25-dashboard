{
  "name": "fs25-dashboard",
  "version": "1.4.2",
  "description": "FS25 Dashboard – real-time web dashboard for Farming Simulator 25",
  "main": "index.js",
  "bin": "index.js",
  "license": "MIT",
  "author": "Sapavlisna",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sapavlisna/fs25-dashboard"
  },
  "bugs": {
    "url": "https://github.com/Sapavlisna/fs25-dashboard/issues"
  },
  "homepage": "https://github.com/Sapavlisna/fs25-dashboard#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node index.js",
    "validate": "node scripts/validate-json.js",
    "mock": "node scripts/mock-data.js",
    "mock:scenario": "node scripts/set-scenario.js",
    "replay": "node scripts/replay.js",
    "test:diag": "node test/diag.test.js",
    "smoke": "playwright test --config=test/smoke/playwright.config.js --reporter=list",
    "test:all": "playwright test --config=test/smoke/playwright.config.js --reporter=list",
    "test:flash": "playwright test --config=test/smoke/playwright.flash.config.js --reporter=list",
    "build": "pkg . --targets node20-win-x64 --output dist/FS25_Dashboard_Server.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "config.example.json"
    ],
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "express": "^4.19.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@yao-pkg/pkg": "^5.16.1"
  }
}
