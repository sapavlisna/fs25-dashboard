# cloud-deploy/.env  —  pro deploy.ps1
#
# Zkopíruj tento soubor jako `.env` (bez .example) a vyplň hodnoty.
# `deploy.ps1` z něj načte konfiguraci a vytvoří službu přes Render API.
#
# Pokud místo skriptu používáš "Deploy to Render" tlačítko v README,
# tento soubor nepotřebuješ — Render se zeptá v UI.

# ─── POVINNÉ ─────────────────────────────────────────────────────────────────

# Render API klíč. Vytvoříš na https://dashboard.render.com/u/settings → API Keys
RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL tvého forku tohoto repa (musíš mít vlastní fork na svém GitHubu)
GITHUB_REPO_URL=https://github.com/TVE-JMENO/fs25-dashboard

# Heslo, kterým se kamarádi přihlásí v prohlížeči.
# Nech prázdné pro veřejně přístupný dashboard (kdokoliv s URL ho otevře).
DASHBOARD_PASSWORD=zmen-toto-heslo

# Tajný token, kterým se tvůj lokální server ověří proti cloudu.
# Pokud necháš prázdné, deploy.ps1 ho vygeneruje sám.
INGEST_TOKEN=

# ─── VOLITELNÉ ───────────────────────────────────────────────────────────────

# Jméno služby — bude součástí URL: https://<SERVICE_NAME>.onrender.com
# Default: fs25-dashboard
SERVICE_NAME=fs25-dashboard

# Region. Frankfurt = nejblíž pro EU. Možnosti: frankfurt, oregon, ohio, singapore.
REGION=frankfurt

# Větev v GitHub repu (default: main)
BRANCH=main
